# ONDEWO NLU TypeScript client — examples configuration template.
#
# This is a NON-SECRET template committed to the repo. Copy real values in
# locally, but NEVER commit real secrets. Every example loads this file via
# dotenv (script-relative), so the values below are read from process.env.

# --- Connection (gRPC-web / envoy endpoint) ---
ONDEWO_HOST=localhost
ONDEWO_PORT=50053

# --- Secure channel ---
# When true the examples build an https:// gRPC-web URL, otherwise http://.
ONDEWO_USE_SECURE_CHANNEL=false
# Optional path to a gRPC TLS certificate file (leave blank for none).
ONDEWO_GRPC_CERT=

# --- Keycloak (headless SDK login: ROPC + offline_access) ---
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak TLS certificate on the token call (set false only for a
# self-signed local Envoy).
KEYCLOAK_VERIFY_SSL=true
